@page "/"
@page "/{locale}"

<div class="content">
    <div style="display: flex; flex-direction: column; align-items: center;  gap: 12px">
        <InputFile OnChange="LoadFile"/>
        @if (ImgBytes.Length != 0)
        {
            <img style="max-height: 300px; width: auto" src="data:image/jpeg;base64, @Convert.ToBase64String(ImgBytes)"
                 alt="Game Image"/>
        }
    </div>
    <div style="display: flex; flex-direction: row; gap: 16px;">
        <button @onclick="OnClickSolve">Решить
        </button>
        <button
            @onclick="()=>Game.Cells.ForEach(x => {x.IsEmpty = null; x.Rule = null; x.Color = Colors.First().Key; })">
            Очистить
        </button>
        <div>@Result</div>
    </div>
    <div class="game-field" style="--game-size: @GameSize">
        @foreach (var row in Game.Cells.Chunk(Game.Size))
        {
            @foreach (var cell in row)
            {
                <div class="game-cell"
                     style="background-color:  @GetColor(cell.Color);"
                     @ontouchend="() => {  cell.IsEmpty = null; cell.Color = CurrentColor; }"
                     @onmouseover="args => { if (args.Buttons == 1) { cell.IsEmpty = null; cell.Color = CurrentColor; }else { Console.WriteLine(cell.Rule); } }"
                     @onmousedown="args => { if (args.Buttons == 1) { cell.IsEmpty = null; cell.Color = CurrentColor; }else { Console.WriteLine(cell.Rule); } }">
                    @(cell.IsEmpty.HasValue ? cell.IsEmpty.Value ? "✖️" : "🐈‍⬛" : string.Empty)
                </div>
            }
        }
    </div>
    <div class="game-settings">
        <input @bind="GameSize"/>
        <div class="game-colors-wrapper">
            @foreach (var color in Colors)
            {
                <div
                    class="game-color @(CurrentColor == color.Key ? "active" : string.Empty)"
                    style="background-color: @color.Value"
                    @onclick="() => { CurrentColor = color.Key; }">
                </div>
            }
        </div>
    </div>
</div>



@code
{
    private async Task OnClickSolve()
    {
        Result = null;
        Result = await Game.SolveAsync() ? " 🎉Решено! 🎉" : "Не получилось решить";
    }

    private async Task LoadFile(InputFileChangeEventArgs e)
    {
        // Get the selected file
        var file = e.File;

        // Define a maximum allowed size (e.g., 5 MB) to protect memory
        long maxFileSize = 1024 * 1024 * 50;

        // Open a stream to read the file contents
        await using var stream = file.OpenReadStream(maxFileSize);
        using var memoryStream = new MemoryStream();

        await stream.CopyToAsync(memoryStream);
        var fileBytes = memoryStream.ToArray();
        ImgBytes = fileBytes;
        try
        {
            var result = GridDetector.DetectGrid(ref fileBytes);
            if (result.Cols != result.Rows)
            {
                return;
            }

            Colors.Clear();

            foreach (var color in result.Cells.Select(x => x.Color).Distinct().Select((x, i) => (index: (i + 1).ToString(), name: $"#{x.Name[2..]}")))
            {
                Colors.Add(color.index, color.name);
            }

            Game = new Game(result.Cols);
            GameSize = result.Cols;

            foreach (var gameCell in Game.Cells)
            {
                var originalCell = result.Cells.First(x => x.Col == gameCell.Index.Y && x.Row == gameCell.Index.X);
                var colorIndex = Colors
                    .FirstOrDefault(x => x.Value == $"#{originalCell.Color.Name[2..]}");
                gameCell.Color = colorIndex.Key;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка: {ex.Message}");
        }
    }

}
